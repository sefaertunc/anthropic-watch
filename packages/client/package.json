{
  "name": "@sefaertunc/anthropic-watch-client",
  "version": "1.0.2",
  "description": "Official client library for consuming anthropic-watch feeds. Version-gated fetch, correct composite-key deduplication, typed errors.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sefaertunc/anthropic-watch.git",
    "directory": "packages/client"
  },
  "bugs": "https://github.com/sefaertunc/anthropic-watch/issues",
  "homepage": "https://github.com/sefaertunc/anthropic-watch/tree/main/packages/client#readme",
  "keywords": [
    "anthropic",
    "claude",
    "rss",
    "json-feed",
    "client",
    "sdk"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc -p . --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "typescript": "^5.5.0"
  }
}
